<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/server_chip_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/tv_glass_focusable_bg"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <FrameLayout
        android:layout_width="42dp"
        android:layout_height="42dp">

        <ImageView
            android:id="@+id/server_chip_avatar_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/tv_avatar_bg"
            android:contentDescription="@string/servers_title"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/server_chip_avatar_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/tv_avatar_bg"
            android:gravity="center"
            android:text="S"
            android:textSize="18sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/server_chip_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Server"
        android:textSize="16sp" />
</LinearLayout>

