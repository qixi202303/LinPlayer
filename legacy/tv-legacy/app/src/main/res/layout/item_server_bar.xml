<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/server_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/tv_focusable_bg"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:orientation="horizontal"
    android:padding="12dp">

    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp">

        <ImageView
            android:id="@+id/server_avatar_img"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/tv_avatar_bg"
            android:contentDescription="@string/servers_title"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/server_avatar_text"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/tv_avatar_bg"
            android:gravity="center"
            android:text="S"
            android:textSize="18sp" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/server_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/server_default_name"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/server_remark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text=""
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
